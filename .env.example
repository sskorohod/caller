# =============================================================
# Caller - Environment Variables
# Copy this file to .env and fill in all required values
# =============================================================

# ----- Domain -----
# Your subdomain (e.g. caller.yourdomain.com)
DOMAIN=caller.yourdomain.com

# ----- PostgreSQL -----
POSTGRES_DB=caller
POSTGRES_USER=caller
POSTGRES_PASSWORD=change_me_strong_password

# ----- Security (REQUIRED - generate with install.sh or manually) -----
# JWT secret: any random string, at least 32 characters
JWT_SECRET=

# Encryption key: exactly 64 hex characters (32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ----- Twilio -----
# Your Twilio Auth Token (used for webhook signature validation)
TWILIO_WEBHOOK_SECRET=

# ----- Logging -----
LOG_LEVEL=info

# ----- OpenAI OAuth Proxy -----
# URL for OpenAI OAuth proxy (used by MCP server for OAuth flow)
OPENAI_OAUTH_PROXY_URL=

# ----- MinIO / S3 Storage (optional) -----
# If configured, call recordings are stored in MinIO instead of Twilio
MINIO_ENDPOINT=
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_USE_SSL=false
MINIO_BUCKET=caller-recordings

# ----- Frontend -----
# API URL as seen from the browser (via CloudFlare/Nginx proxy)
NEXT_PUBLIC_API_URL=/api
